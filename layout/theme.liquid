<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    {% # Inlined CSS Variables %}
    {% render 'css-variables' %}

    {% comment %}
      Font preloading:
      1. Preconnect to font CDN for faster connection
      2. Preload critical font variants (heading and body)
      3. Additional variants load on-demand via @font-face
    {% endcomment %}
    <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>

    {% comment %} Preload heading font {% endcomment %}
    {% unless settings.type_heading_font.system? %}
      {{ settings.type_heading_font | font_url | preload_tag: as: 'font', crossorigin: 'anonymous' }}
    {% endunless %}

    {% comment %} Preload body font {% endcomment %}
    {% unless settings.type_body_font.system? %}
      {{ settings.type_body_font | font_url | preload_tag: as: 'font', crossorigin: 'anonymous' }}
    {% endunless %}

    {% # Load and preload the critical CSS %}
    {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}

    {% # Social, title, etc. %}
    {% render 'meta-tags' %}

    {{ content_for_header }}

    {% # Lucide Icons %}
    <script src="{{ 'lucide.min.js' | asset_url }}"></script>
    <script>
      // Initialize Lucide icons when DOM is ready
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function() {
          if (typeof lucide !== 'undefined') {
            lucide.createIcons();
          }
        });
      } else {
        if (typeof lucide !== 'undefined') {
          lucide.createIcons();
        }
      }
    </script>
  </head>

  <body>
    {% sections 'header-group' %}

    {{ content_for_layout }}

    {% sections 'footer-group' %}
  </body>
</html>
