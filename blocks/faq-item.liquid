{% doc %}
  Renders an individual FAQ item with expandable accordion behavior.

  @example
  {% content_for 'block', type: 'faq-item', id: 'faq-1' %}
{% enddoc %}

{%- liquid
  assign question = block.settings.question | default: ''
  assign answer = block.settings.answer | default: ''
  assign unique_id = 'faq-' | append: block.id
-%}

{%- if question != blank and answer != blank -%}
  <div
    class="faq-item"
    data-faq-item
    {{ block.shopify_attributes }}
  >
    <button
      class="faq-item__question"
      data-faq-button
      aria-expanded="false"
      aria-controls="{{ unique_id }}"
      type="button"
    >
      <span class="faq-item__question-text">{{ question }}</span>
      <span class="faq-item__icon" aria-hidden="true">
        <i data-lucide="chevron-down"></i>
      </span>
    </button>

    <div
      class="faq-item__answer-wrapper"
      id="{{ unique_id }}"
      data-faq-content
      aria-hidden="true"
    >
      <div class="faq-item__answer">
        {{ answer }}
      </div>
    </div>
  </div>
{%- endif -%}

{% stylesheet %}
  .faq-item {
    border-bottom: 1px solid #e5e7eb;
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 0.5s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }

  .faq-item:nth-child(1) { animation-delay: 0.1s; }
  .faq-item:nth-child(2) { animation-delay: 0.15s; }
  .faq-item:nth-child(3) { animation-delay: 0.2s; }
  .faq-item:nth-child(4) { animation-delay: 0.25s; }
  .faq-item:nth-child(5) { animation-delay: 0.3s; }
  .faq-item:nth-child(6) { animation-delay: 0.35s; }
  .faq-item:nth-child(7) { animation-delay: 0.4s; }
  .faq-item:nth-child(8) { animation-delay: 0.45s; }
  .faq-item:nth-child(9) { animation-delay: 0.5s; }
  .faq-item:nth-child(10) { animation-delay: 0.55s; }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .faq-item:last-child {
    border-bottom: none;
  }

  .faq-item__question {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.5rem 0;
    background: transparent;
    border: none;
    cursor: pointer;
    text-align: left;
    transition: all 0.3s ease;
    position: relative;
  }

  .faq-item__question::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(0, 0, 0, 0.02), transparent);
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .faq-item__question:hover::before {
    opacity: 1;
  }

  .faq-item__question:hover {
    padding-left: 0.75rem;
  }

  .faq-item__question:focus {
    outline: none;
  }

  .faq-item__question:focus-visible {
    outline: 2px solid #3b82f6;
    outline-offset: 2px;
    border-radius: 4px;
  }

  .faq-item__question-text {
    flex: 1;
    font-size: 1.0625rem;
    font-weight: 600;
    color: #1f2937;
    line-height: 1.5;
    transition: color 0.3s ease;
  }

  .faq-item__question:hover .faq-item__question-text {
    color: #111827;
  }

  .faq-item__icon {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #6b7280;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1), color 0.3s ease;
  }

  .faq-item__icon i,
  .faq-item__icon svg {
    width: 100%;
    height: 100%;
  }

  .faq-item__question:hover .faq-item__icon {
    color: #374151;
  }

  .faq-item__question[aria-expanded="true"] .faq-item__icon {
    transform: rotate(180deg);
    color: #111827;
  }

  .faq-item__answer-wrapper {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
  }

  .faq-item__answer-wrapper[aria-hidden="false"] {
    grid-template-rows: 1fr;
  }

  .faq-item__answer {
    min-height: 0;
    padding: 0 0 1.5rem 0;
    opacity: 0;
    transform: translateY(-10px);
    transition: opacity 0.3s ease 0.1s, transform 0.3s ease 0.1s;
  }

  .faq-item__answer-wrapper[aria-hidden="false"] .faq-item__answer {
    opacity: 1;
    transform: translateY(0);
  }

  .faq-item__answer {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: #4b5563;
  }

  .faq-item__answer p {
    margin: 0 0 1rem 0;
  }

  .faq-item__answer p:last-child {
    margin-bottom: 0;
  }

  .faq-item__answer ul,
  .faq-item__answer ol {
    margin: 0 0 1rem 1.5rem;
    padding: 0;
  }

  .faq-item__answer li {
    margin-bottom: 0.5rem;
  }

  .faq-item__answer a {
    color: #3b82f6;
    text-decoration: underline;
    transition: color 0.2s ease;
  }

  .faq-item__answer a:hover {
    color: #2563eb;
  }

  @media (max-width: 768px) {
    .faq-item__question {
      padding: 1.25rem 0;
      gap: 1rem;
    }

    .faq-item__question-text {
      font-size: 1rem;
    }

    .faq-item__icon {
      width: 20px;
      height: 20px;
    }

    .faq-item__answer {
      padding: 0 0 1.25rem 0;
      font-size: 0.875rem;
    }
  }

  /* Reduce motion for users who prefer it */
  @media (prefers-reduced-motion: reduce) {
    .faq-item,
    .faq-item__icon,
    .faq-item__answer-wrapper,
    .faq-item__answer,
    .faq-item__question::before {
      animation: none !important;
      transition-duration: 0.01ms !important;
    }

    .faq-item {
      opacity: 1 !important;
      transform: none !important;
    }

    .faq-item__answer-wrapper[aria-hidden="false"] .faq-item__answer {
      opacity: 1 !important;
      transform: none !important;
    }
  }
{% endstylesheet %}

{% javascript %}
  class FAQAccordion {
    constructor(faqItem) {
      this.item = faqItem;
      this.button = faqItem.querySelector('[data-faq-button]');
      this.content = faqItem.querySelector('[data-faq-content]');

      if (this.button && this.content) {
        this.init();
      }
    }

    init() {
      this.button.addEventListener('click', () => this.toggle());

      // Keyboard accessibility
      this.button.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          this.toggle();
        }
      });

      // Initialize Lucide icons
      if (typeof lucide !== 'undefined') {
        lucide.createIcons();
      }
    }

    toggle() {
      const isExpanded = this.button.getAttribute('aria-expanded') === 'true';

      if (isExpanded) {
        this.close();
      } else {
        this.open();
      }
    }

    open() {
      this.button.setAttribute('aria-expanded', 'true');
      this.content.setAttribute('aria-hidden', 'false');
    }

    close() {
      this.button.setAttribute('aria-expanded', 'false');
      this.content.setAttribute('aria-hidden', 'true');
    }
  }

  // Initialize all FAQ items
  function initFAQAccordions() {
    const faqItems = document.querySelectorAll('[data-faq-item]');
    faqItems.forEach(item => new FAQAccordion(item));
  }

  // Initialize on page load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFAQAccordions);
  } else {
    initFAQAccordions();
  }

  // Reinitialize on Shopify section updates
  if (typeof Shopify !== 'undefined' && Shopify.designMode) {
    document.addEventListener('shopify:section:load', initFAQAccordions);
  }
{% endjavascript %}

{% schema %}
{
  "name": "t:general.faq_item",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "question",
      "label": "t:labels.question",
      "default": "What is your return policy?"
    },
    {
      "type": "richtext",
      "id": "answer",
      "label": "t:labels.answer",
      "default": "<p>We offer a 30-day return policy on all products. Items must be unused and in original packaging.</p>"
    }
  ],
  "presets": [
    {
      "name": "t:general.faq_item",
      "category": "t:general.content"
    }
  ]
}
{% endschema %}
