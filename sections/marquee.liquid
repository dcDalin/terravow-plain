{%- liquid
  assign bg_color = section.settings.background_color | default: '#000000'
  assign text_color = section.settings.text_color | default: '#ffffff'
  assign font_size = section.settings.font_size | default: 16
  assign speed = section.settings.speed | default: 30
  assign padding = section.settings.padding | default: 16
  assign gap = section.settings.gap | default: 32
  assign direction = section.settings.direction | default: 'normal'
-%}

<div
  class="marquee-section full-width"
  style="
    --marquee-bg: {{ bg_color }};
    --marquee-text: {{ text_color }};
    --marquee-font-size: {{ font_size }}px;
    --marquee-speed: {{ speed }}s;
    --marquee-padding: {{ padding }}px;
    --marquee-gap: {{ gap }}px;
    --marquee-direction: {{ direction }};
  "
>
  <div class="marquee-section__wrapper">
    <div class="marquee-section__content">
      <div class="marquee-section__items">
        {%- for block in section.blocks -%}
          <span {{ block.shopify_attributes }}>
            {%- render block -%}
          </span>
          {%- if section.settings.divider != blank and forloop.last == false -%}
            <span class="marquee-section__divider">{{ section.settings.divider }}</span>
          {%- endif -%}
        {%- endfor -%}
      </div>
      <div class="marquee-section__items" aria-hidden="true">
        {%- for block in section.blocks -%}
          <span>
            {%- render block -%}
          </span>
          {%- if section.settings.divider != blank and forloop.last == false -%}
            <span class="marquee-section__divider">{{ section.settings.divider }}</span>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .marquee-section {
    background-color: var(--marquee-bg);
    color: var(--marquee-text);
    padding: var(--marquee-padding) 0;
    overflow: hidden;
    width: 100%;
  }

  .marquee-section__wrapper {
    display: flex;
    gap: var(--marquee-gap);
    width: fit-content;
    white-space: nowrap;
  }

  .marquee-section__content {
    min-width: max-content;
    display: flex;
    gap: var(--marquee-gap);
  }

  .marquee-section__items {
    min-width: max-content;
    display: flex;
    gap: var(--marquee-gap);
    align-items: center;
    font-size: var(--marquee-font-size);
  }

  .marquee-section__items > span {
    display: inline-flex;
    align-items: center;
  }

  .text-block {
    white-space: nowrap;
  }

  .image-block {
    display: inline-flex;
    align-items: center;
  }

  .image-block img {
    display: block;
    height: auto;
  }

  .icon-block {
    display: inline-flex;
    align-items: center;
  }

  .marquee-section__divider {
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
  }

  @media (prefers-reduced-motion: no-preference) {
    .marquee-section__wrapper {
      animation: marquee-motion var(--marquee-speed) linear infinite var(--marquee-direction);
    }
  }

  @keyframes marquee-motion {
    to {
      transform: translate3d(calc(-50% - (var(--marquee-gap) / 2)), 0, 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-section__wrapper {
      animation: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.marquee",
  "blocks": [
    {
      "type": "text"
    },
    {
      "type": "image"
    },
    {
      "type": "icon"
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "t:general.style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:labels.background_color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:labels.text_color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "t:labels.font_size",
      "min": 12,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding",
      "label": "t:labels.padding",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between items",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "text",
      "id": "divider",
      "label": "Divider",
      "info": "Optional divider between items",
      "default": "•"
    },
    {
      "type": "header",
      "content": "t:labels.animation"
    },
    {
      "type": "select",
      "id": "direction",
      "label": "t:labels.direction",
      "options": [
        {
          "value": "normal",
          "label": "t:options.direction.left"
        },
        {
          "value": "reverse",
          "label": "t:options.direction.right"
        }
      ],
      "default": "normal"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "t:labels.speed",
      "info": "t:labels.speed_info",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "s",
      "default": 30
    }
  ],
  "presets": [
    {
      "name": "t:general.marquee",
      "category": "t:general.content",
      "blocks": [
        {
          "type": "text"
        },
        {
          "type": "icon"
        },
        {
          "type": "text"
        }
      ]
    }
  ]
}
{% endschema %}
