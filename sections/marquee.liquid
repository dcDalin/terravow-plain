{%- liquid
  assign bg_color = section.settings.background_color | default: '#000000'
  assign text_color = section.settings.text_color | default: '#ffffff'
  assign font_size = section.settings.font_size | default: 16
  assign speed = section.settings.speed | default: 30
  assign padding_top = section.settings.padding_top | default: 16
  assign padding_bottom = section.settings.padding_bottom | default: 16
  assign gap = section.settings.gap | default: 32
  assign direction = section.settings.direction | default: 'normal'
  assign separator = section.settings.separator | default: '•'
-%}

<div
  class="marquee-section full-width"
  style="
    --marquee-bg: {{ bg_color }};
    --marquee-text: {{ text_color }};
    --marquee-font-size: {{ font_size }}px;
    --marquee-speed: {{ speed }}s;
    --marquee-padding-top: {{ padding_top }}px;
    --marquee-padding-bottom: {{ padding_bottom }}px;
    --marquee-gap: {{ gap }}px;
    --marquee-direction: {{ direction }};
  "
>
  <div class="marquee-section__wrapper">
    {%- for i in (1..4) -%}
      <div class="marquee-section__content" {% if i > 1 %}aria-hidden="true"{% endif %}>
        {%- for block in section.blocks -%}
          <div class="marquee-section__item" {% if i == 1 %}{{ block.shopify_attributes }}{% endif %}>
            {%- if block.settings.icon != blank -%}
              <span class="marquee-section__icon">{{ block.settings.icon }}</span>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <span class="marquee-section__text">{{ block.settings.text }}</span>
            {%- endif -%}
          </div>
          {%- unless forloop.last and separator == blank -%}
            {%- if separator != blank -%}
              <span class="marquee-section__separator">{{ separator }}</span>
            {%- endif -%}
          {%- endunless -%}
        {%- endfor -%}
      </div>
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
  .marquee-section {
    background-color: var(--marquee-bg);
    color: var(--marquee-text);
    padding: var(--marquee-padding-top) 0 var(--marquee-padding-bottom) 0;
    overflow: hidden;
    width: 100%;
  }

  .marquee-section__wrapper {
    display: flex;
    gap: var(--marquee-gap);
    width: max-content;
    white-space: nowrap;
    will-change: transform;
  }

  .marquee-section__content {
    display: flex;
    gap: var(--marquee-gap);
    align-items: center;
    font-size: var(--marquee-font-size);
    flex-shrink: 0;
  }

  .marquee-section__item {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .marquee-section__icon {
    display: inline-flex;
    align-items: center;
  }

  .marquee-section__text {
    white-space: nowrap;
  }

  .marquee-section__separator {
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
  }

  @media (prefers-reduced-motion: no-preference) {
    .marquee-section__wrapper {
      animation: marquee-motion var(--marquee-speed) linear infinite var(--marquee-direction);
    }

    .marquee-section:has(.marquee-section__item:hover) .marquee-section__wrapper {
      animation-play-state: paused;
    }
  }

  @keyframes marquee-motion {
    0% {
      transform: translate3d(0, 0, 0);
    }
    100% {
      transform: translate3d(-25%, 0, 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-section__wrapper {
      animation: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.marquee",
  "blocks": [
    {
      "type": "item",
      "name": "Marquee item",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon",
          "info": "Enter emoji or icon character",
          "default": "★"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Marquee item"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "t:general.style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:labels.background_color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:labels.text_color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "t:labels.font_size",
      "min": 12,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between items",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "text",
      "id": "separator",
      "label": "Separator",
      "info": "Optional separator between items",
      "default": "•"
    },
    {
      "type": "header",
      "content": "t:labels.animation"
    },
    {
      "type": "select",
      "id": "direction",
      "label": "t:labels.direction",
      "options": [
        {
          "value": "normal",
          "label": "t:options.direction.left"
        },
        {
          "value": "reverse",
          "label": "t:options.direction.right"
        }
      ],
      "default": "normal"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "t:labels.speed",
      "info": "t:labels.speed_info",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "s",
      "default": 30
    }
  ],
  "presets": [
    {
      "name": "t:general.marquee",
      "category": "t:general.content",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "icon": "★",
            "text": "Welcome to our store"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "🚚",
            "text": "Free shipping"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "✨",
            "text": "Shop now"
          }
        }
      ]
    }
  ]
}
{% endschema %}
