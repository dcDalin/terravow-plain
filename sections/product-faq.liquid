{%- liquid
  assign faqs = product.metafields.custom.product_faq.value
  assign faqs_count = faqs | size | default: 0
  assign heading = section.settings.heading | default: ''
  assign heading_alignment = section.settings.heading_alignment | default: 'center'
-%}

{%- if faqs_count > 0 -%}
  <div class="product-faq-section" data-product-faq-section>
    <div class="product-faq-section__container">
      {%- if heading != blank -%}
        <h2 class="product-faq-section__heading" style="--heading-align: {{ heading_alignment }}">{{ heading }}</h2>
      {%- endif -%}

      <div class="product-faq-section__items">
        {%- for faq in faqs -%}
          {%- assign unique_id = 'product-faq-' | append: section.id | append: '-' | append: forloop.index -%}
          {%- if faq.title != blank and faq.description != blank -%}
            <div
              class="product-faq-item"
              data-product-faq-item
            >
              <button
                class="product-faq-item__question"
                data-product-faq-button
                aria-expanded="false"
                aria-controls="{{ unique_id }}"
                type="button"
              >
                <span class="product-faq-item__question-text">{{ faq.title }}</span>
                <span class="product-faq-item__icon" aria-hidden="true">
                  <i data-lucide="chevron-down"></i>
                </span>
              </button>

              <div
                class="product-faq-item__answer-wrapper"
                id="{{ unique_id }}"
                data-product-faq-content
                aria-hidden="true"
              >
                <div class="product-faq-item__answer">
                  {{ faq.description | metafield_tag }}
                </div>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
{%- endif -%}

{% stylesheet %}
  .product-faq-section {
    width: 100%;
    padding: 2rem 0;
  }

  .product-faq-section__container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .product-faq-section__heading {
    font-size: 1.875rem;
    font-weight: 700;
    text-align: var(--heading-align, center);
    color: #111827;
    margin: 0 0 1.5rem 0;
    opacity: 0;
    transform: translateY(-20px);
    animation: productFaqFadeInDown 0.6s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }

  @keyframes productFaqFadeInDown {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .product-faq-section__items {
    display: flex;
    flex-direction: column;
  }

  .product-faq-item {
    border-bottom: 1px solid #e5e7eb;
    opacity: 0;
    transform: translateY(20px);
    animation: productFaqFadeInUp 0.5s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }

  .product-faq-item:first-child {
    border-top: 1px solid #e5e7eb;
  }

  .product-faq-item:nth-child(1) { animation-delay: 0.1s; }
  .product-faq-item:nth-child(2) { animation-delay: 0.15s; }
  .product-faq-item:nth-child(3) { animation-delay: 0.2s; }
  .product-faq-item:nth-child(4) { animation-delay: 0.25s; }
  .product-faq-item:nth-child(5) { animation-delay: 0.3s; }
  .product-faq-item:nth-child(6) { animation-delay: 0.35s; }
  .product-faq-item:nth-child(7) { animation-delay: 0.4s; }
  .product-faq-item:nth-child(8) { animation-delay: 0.45s; }
  .product-faq-item:nth-child(9) { animation-delay: 0.5s; }
  .product-faq-item:nth-child(10) { animation-delay: 0.55s; }

  @keyframes productFaqFadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .product-faq-item__question {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 14px 0;
    background: transparent;
    border: none;
    cursor: pointer;
    text-align: left;
  }

  .product-faq-item__question:focus {
    outline: none;
  }

  .product-faq-item__question:focus-visible {
    outline: 2px solid #3b82f6;
    outline-offset: 2px;
    border-radius: 4px;
  }

  .product-faq-item__question-text {
    flex: 1;
    font-size: 1rem;
    font-weight: 600;
    color: #1f2937;
    line-height: 1.5;
    transition: color 0.2s ease;
  }

  .product-faq-item__question:hover .product-faq-item__question-text {
    color: #6b7280;
  }

  .product-faq-item__icon {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #6b7280;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .product-faq-item__icon i,
  .product-faq-item__icon svg {
    width: 100%;
    height: 100%;
  }

  .product-faq-item__question[aria-expanded="true"] .product-faq-item__icon {
    transform: rotate(180deg);
  }

  .product-faq-item__answer-wrapper {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
  }

  .product-faq-item__answer-wrapper[aria-hidden="false"] {
    grid-template-rows: 1fr;
  }

  .product-faq-item__answer {
    min-height: 0;
    padding: 0 0 14px 0;
    opacity: 0;
    transform: translateY(-8px);
    transition: opacity 0.3s ease 0.1s, transform 0.3s ease 0.1s;
    font-size: 0.9rem;
    line-height: 1.6;
    color: #4b5563;
  }

  .product-faq-item__answer-wrapper[aria-hidden="false"] .product-faq-item__answer {
    opacity: 1;
    transform: translateY(0);
  }

  .product-faq-item__answer p {
    margin: 0 0 0.75rem 0;
  }

  .product-faq-item__answer p:last-child {
    margin-bottom: 0;
  }

  .product-faq-item__answer ul,
  .product-faq-item__answer ol {
    margin: 0 0 0.75rem 1.5rem;
    padding: 0;
  }

  .product-faq-item__answer li {
    margin-bottom: 0.375rem;
  }

  .product-faq-item__answer a {
    color: #3b82f6;
    text-decoration: underline;
    transition: color 0.2s ease;
  }

  .product-faq-item__answer a:hover {
    color: #2563eb;
  }

  @media (max-width: 768px) {
    .product-faq-section {
      padding: 1.5rem 0;
    }

    .product-faq-section__container {
      padding: 0 1rem;
    }

    .product-faq-section__heading {
      font-size: 1.5rem;
      margin-bottom: 1.25rem;
    }

    .product-faq-item__question-text {
      font-size: 0.9375rem;
    }

    .product-faq-item__answer {
      font-size: 0.875rem;
    }
  }

  @media (max-width: 480px) {
    .product-faq-section__heading {
      font-size: 1.375rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .product-faq-section__heading,
    .product-faq-item,
    .product-faq-item__icon,
    .product-faq-item__answer-wrapper,
    .product-faq-item__answer {
      animation: none !important;
      transition-duration: 0.01ms !important;
    }

    .product-faq-section__heading,
    .product-faq-item {
      opacity: 1 !important;
      transform: none !important;
    }

    .product-faq-item__answer-wrapper[aria-hidden="false"] .product-faq-item__answer {
      opacity: 1 !important;
      transform: none !important;
    }
  }
{% endstylesheet %}

{% javascript %}
  class ProductFAQAccordion {
    constructor(faqItem) {
      this.item = faqItem;
      this.button = faqItem.querySelector('[data-product-faq-button]');
      this.content = faqItem.querySelector('[data-product-faq-content]');

      if (this.button && this.content) {
        this.init();
      }
    }

    init() {
      this.button.addEventListener('click', () => this.toggle());

      this.button.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          this.toggle();
        }
      });
    }

    toggle() {
      const isExpanded = this.button.getAttribute('aria-expanded') === 'true';
      isExpanded ? this.close() : this.open();
    }

    open() {
      this.button.setAttribute('aria-expanded', 'true');
      this.content.setAttribute('aria-hidden', 'false');
    }

    close() {
      this.button.setAttribute('aria-expanded', 'false');
      this.content.setAttribute('aria-hidden', 'true');
    }
  }

  function initProductFAQAccordions() {
    document.querySelectorAll('[data-product-faq-item]').forEach(item => new ProductFAQAccordion(item));
    if (typeof lucide !== 'undefined') lucide.createIcons();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initProductFAQAccordions);
  } else {
    initProductFAQAccordions();
  }

  if (typeof Shopify !== 'undefined' && Shopify.designMode) {
    document.addEventListener('shopify:section:load', initProductFAQAccordions);
  }
{% endjavascript %}

{% schema %}
{
  "name": "t:general.product_faq",
  "settings": [
    {
      "type": "header",
      "content": "t:general.content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "t:labels.title_alignment",
      "options": [
        {
          "value": "left",
          "label": "t:options.alignment.left"
        },
        {
          "value": "center",
          "label": "t:options.alignment.center"
        },
        {
          "value": "right",
          "label": "t:options.alignment.right"
        }
      ],
      "default": "center"
    }
  ],
  "presets": [
    {
      "name": "t:general.product_faq",
      "category": "t:general.product"
    }
  ],
  "enabled_on": {
    "templates": ["product"]
  }
}
{% endschema %}
