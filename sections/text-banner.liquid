{%- liquid
  assign heading = section.settings.heading | default: ''
  assign description = section.settings.description | default: ''
  assign heading_size = section.settings.heading_size | default: 'h2'
  assign text_alignment = section.settings.text_alignment | default: 'center'
  assign content_alignment = section.settings.content_alignment | default: 'center'
  assign bg_color = section.settings.background_color | default: 'transparent'
  assign text_color = section.settings.text_color | default: '#000000'
  assign max_width = section.settings.max_width | default: 800
  assign padding_top = section.settings.padding_top | default: 60
  assign padding_bottom = section.settings.padding_bottom | default: 60
-%}

<div
  class="text-banner full-width"
  style="
    --text-banner-bg: {{ bg_color }};
    --text-banner-text: {{ text_color }};
    --text-banner-max-width: {{ max_width }}px;
    --text-banner-padding-top: {{ padding_top }}px;
    --text-banner-padding-bottom: {{ padding_bottom }}px;
    --text-banner-text-align: {{ text_alignment }};
    --text-banner-content-align: {{ content_alignment }};
  "
>
  <div class="text-banner__container">
    <div class="text-banner__content">
      {%- if heading != blank -%}
        <{{ heading_size }} class="text-banner__heading">
          {{ heading }}
        </{{ heading_size }}>
      {%- endif -%}

      {%- if description != blank -%}
        <div class="text-banner__description">
          {{ description }}
        </div>
      {%- endif -%}

      {%- if section.settings.button_text != blank and section.settings.button_link != blank -%}
        <div class="text-banner__button-wrapper">
          <a href="{{ section.settings.button_link }}" class="text-banner__button">
            {{ section.settings.button_text }}
          </a>
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .text-banner {
    background-color: var(--text-banner-bg);
    color: var(--text-banner-text);
    padding: var(--text-banner-padding-top) 20px var(--text-banner-padding-bottom);
    width: 100%;
  }

  .text-banner__container {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    justify-content: var(--text-banner-content-align);
  }

  .text-banner__content {
    max-width: var(--text-banner-max-width);
    width: 100%;
    text-align: var(--text-banner-text-align);
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .text-banner__heading {
    margin: 0;
    line-height: 1.2;
  }

  .text-banner__heading.h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
  }

  .text-banner__heading.h2 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
  }

  .text-banner__heading.h3 {
    font-size: clamp(1.5rem, 3vw, 2rem);
  }

  .text-banner__heading.h4 {
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
  }

  .text-banner__description {
    font-size: 16px;
    line-height: 1.6;
    opacity: 0.9;
  }

  .text-banner__description p {
    margin: 0;
  }

  .text-banner__description p + p {
    margin-top: 1em;
  }

  .text-banner__button-wrapper {
    margin-top: 12px;
  }

  .text-banner__button {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 32px;
    background: var(--text-banner-text);
    color: var(--text-banner-bg);
    text-decoration: none;
    border-radius: 4px;
    font-weight: 600;
    font-size: 15px;
    position: relative;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .text-banner__button::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
    transition: left 0.5s ease;
  }

  .text-banner__button::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.1) 0%, rgba(255, 255, 255, 0.05) 100%);
    opacity: 0;
    transition: opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    border-radius: 4px;
  }

  .text-banner__button:hover::before {
    left: 100%;
  }

  .text-banner__button:hover::after {
    opacity: 1;
  }

  .text-banner__button:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
  }

  .text-banner__button:active {
    transform: translateY(-1px);
    transition: all 0.1s ease;
  }

  @media (max-width: 768px) {
    .text-banner {
      padding: calc(var(--text-banner-padding-top) * 0.7) 16px calc(var(--text-banner-padding-bottom) * 0.7);
    }

    .text-banner__content {
      gap: 16px;
    }

    .text-banner__description {
      font-size: 15px;
    }

    .text-banner__button {
      padding: 12px 28px;
      font-size: 14px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.text_banner",
  "settings": [
    {
      "type": "header",
      "content": "t:general.content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Welcome to our store"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:labels.heading_size",
      "options": [
        {
          "value": "h1",
          "label": "t:options.heading_size.extra_large"
        },
        {
          "value": "h2",
          "label": "t:options.heading_size.large"
        },
        {
          "value": "h3",
          "label": "t:options.heading_size.medium"
        },
        {
          "value": "h4",
          "label": "t:options.heading_size.small"
        }
      ],
      "default": "h2"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:labels.description",
      "default": "<p>Add your text content here. You can format it with multiple paragraphs.</p>"
    },
    {
      "type": "header",
      "content": "t:general.button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "t:labels.button_text"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:labels.button_link"
    },
    {
      "type": "header",
      "content": "t:general.layout"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "t:labels.text_alignment",
      "options": [
        {
          "value": "left",
          "label": "t:options.alignment.left"
        },
        {
          "value": "center",
          "label": "t:options.alignment.center"
        },
        {
          "value": "right",
          "label": "t:options.alignment.right"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "t:labels.content_position",
      "options": [
        {
          "value": "flex-start",
          "label": "t:options.alignment.left"
        },
        {
          "value": "center",
          "label": "t:options.alignment.center"
        },
        {
          "value": "flex-end",
          "label": "t:options.alignment.right"
        }
      ],
      "default": "center",
      "info": "Position of content block within section"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "t:labels.content_width",
      "min": 400,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "default": 800
    },
    {
      "type": "header",
      "content": "t:general.colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:labels.background_color",
      "default": "#f5f5f5"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:labels.text_color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "t:general.spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:labels.padding_top",
      "min": 0,
      "max": 120,
      "step": 10,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:labels.padding_bottom",
      "min": 0,
      "max": 120,
      "step": 10,
      "unit": "px",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "t:general.text_banner",
      "category": "t:general.text"
    }
  ]
}
{% endschema %}
