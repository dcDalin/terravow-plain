{%- liquid
  assign hiw_images = product.metafields.custom.how_it_works.value
  assign items_count = hiw_images.size | default: 0
  assign heading = section.settings.heading | default: ''
  assign title_alignment = section.settings.title_alignment | default: 'left'
  assign autoplay = section.settings.autoplay
  assign autoplay_speed = section.settings.autoplay_speed | default: 3
  assign show_arrows = section.settings.show_arrows
-%}

{%- if items_count > 0 -%}
  <div
    class="product-hiw"
    data-autoplay="{{ autoplay }}"
    data-autoplay-speed="{{ autoplay_speed }}"
  >
    <div class="product-hiw__container">
      {%- if heading != blank -%}
        <div class="product-hiw__header" style="--title-alignment: {{ title_alignment }}">
          <h2 class="product-hiw__heading">{{ heading }}</h2>
        </div>
      {%- endif -%}

      <div class="product-hiw__carousel-wrapper">
        {%- if show_arrows and items_count > 1 -%}
          <button class="product-hiw__nav product-hiw__nav--prev" type="button" aria-label="Previous image">
            <i data-lucide="chevron-left"></i>
          </button>
        {%- endif -%}

        <div class="product-hiw__carousel-container">
          <div class="product-hiw__carousel-track">
            {%- for image in hiw_images -%}
              <div class="product-hiw__slide" data-slide-index="{{ forloop.index0 }}">
                <div class="product-hiw__image-wrapper">
                  {{
                    image
                    | image_url: width: 800
                    | image_tag:
                      alt: product.title,
                      loading: 'lazy',
                      class: 'product-hiw__image'
                  }}
                </div>
              </div>
            {%- endfor -%}
          </div>
        </div>

        {%- if show_arrows and items_count > 1 -%}
          <button class="product-hiw__nav product-hiw__nav--next" type="button" aria-label="Next image">
            <i data-lucide="chevron-right"></i>
          </button>
        {%- endif -%}
      </div>

      {%- if items_count > 1 -%}
        <div class="product-hiw__dots">
          {%- for image in hiw_images -%}
            <button
              class="product-hiw__dot{% if forloop.first %} active{% endif %}"
              data-dot-index="{{ forloop.index0 }}"
              aria-label="Go to image {{ forloop.index }}"
              type="button"
            ></button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
{%- endif -%}

{% stylesheet %}
  .product-hiw,
  .product-hiw *,
  .product-hiw *::before,
  .product-hiw *::after {
    box-sizing: border-box;
  }

  .product-hiw {
    width: 100%;
    padding: 2rem 0;
    overflow-x: hidden;
  }

  .product-hiw__container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 1rem;
    width: 100%;
  }

  @media (min-width: 768px) {
    .product-hiw__container {
      padding: 0 1.5rem;
    }
  }

  @media (min-width: 1024px) {
    .product-hiw__container {
      padding: 0 2rem;
    }
  }

  /* Heading */
  .product-hiw__header {
    text-align: var(--title-alignment, left);
    margin-bottom: 1.25rem;
  }

  @media (min-width: 768px) {
    .product-hiw__header {
      margin-bottom: 1.5rem;
    }
  }

  .product-hiw__heading {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0;
    line-height: 1.2;
  }

  @media (min-width: 768px) {
    .product-hiw__heading {
      font-size: 1.75rem;
    }
  }

  @media (min-width: 1024px) {
    .product-hiw__heading {
      font-size: 2rem;
    }
  }

  /* Carousel wrapper — reserves space for nav arrows */
  .product-hiw__carousel-wrapper {
    position: relative;
    margin: 0 52px;
    width: calc(100% - 104px);
  }

  @media (max-width: 767px) {
    .product-hiw__carousel-wrapper {
      margin: 0 40px;
      width: calc(100% - 80px);
    }
  }

  .product-hiw__carousel-container {
    overflow: hidden;
    width: 100%;
  }

  .product-hiw__carousel-track {
    display: flex;
    gap: 24px;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
  }

  .product-hiw__carousel-track.no-transition {
    transition: none;
  }

  /* 3 per view on desktop */
  .product-hiw__slide {
    flex: 0 0 calc((100% - 48px) / 3);
    min-width: 0;
  }

  /* 2 per view on tablet */
  @media (max-width: 1024px) {
    .product-hiw__carousel-track {
      gap: 16px;
    }

    .product-hiw__slide {
      flex: 0 0 calc((100% - 16px) / 2);
    }
  }

  /* 1 per view on mobile */
  @media (max-width: 767px) {
    .product-hiw__carousel-track {
      gap: 0;
    }

    .product-hiw__slide {
      flex: 0 0 100%;
    }
  }

  /* Image */
  .product-hiw__image-wrapper {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
    border-radius: 0.75rem;
    background: #f5f5f5;
  }

  @media (min-width: 768px) {
    .product-hiw__image-wrapper {
      border-radius: 1rem;
    }
  }

  .product-hiw__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Nav arrows */
  .product-hiw__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: none;
    border: none;
    cursor: pointer;
    color: #333;
    transition: color 0.2s ease;
  }

  .product-hiw__nav i {
    width: 22px;
    height: 22px;
    transition: transform 0.2s ease;
  }

  .product-hiw__nav:hover i {
    transform: scale(1.2);
  }

  .product-hiw__nav--prev {
    left: -52px;
  }

  .product-hiw__nav--next {
    right: -52px;
  }

  @media (max-width: 767px) {
    .product-hiw__nav {
      width: 36px;
      height: 36px;
    }

    .product-hiw__nav i {
      width: 18px;
      height: 18px;
    }

    .product-hiw__nav--prev {
      left: -40px;
    }

    .product-hiw__nav--next {
      right: -40px;
    }
  }

  /* Dots */
  .product-hiw__dots {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .product-hiw__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: none;
    background: rgba(0, 0, 0, 0.2);
    cursor: pointer;
    padding: 0;
    transition: all 0.2s ease;
  }

  .product-hiw__dot.active {
    background: var(--color-foreground, #000);
    width: 24px;
    border-radius: 4px;
  }

  .product-hiw__dot:hover:not(.active) {
    background: rgba(0, 0, 0, 0.4);
  }
{% endstylesheet %}

{% javascript %}
  class ProductHowItWorks {
    constructor(container) {
      this.container = container;
      this.track = container.querySelector('.product-hiw__carousel-track');
      this.slides = Array.from(container.querySelectorAll('[data-slide-index]'));
      this.dots = Array.from(container.querySelectorAll('[data-dot-index]'));
      this.prevBtn = container.querySelector('.product-hiw__nav--prev');
      this.nextBtn = container.querySelector('.product-hiw__nav--next');

      this.autoplay = container.dataset.autoplay === 'true';
      this.autoplaySpeed = parseInt(container.dataset.autoplaySpeed) * 1000;

      this.currentIndex = 0;
      this.isTransitioning = false;
      this.isPaused = false;
      this.autoplayInterval = null;
      this.resumeTimeout = null;
      this.touchStartX = 0;
      this.touchEndX = 0;

      this.slidesPerView = this.getSlidesPerView();

      if (this.slides.length > this.slidesPerView) {
        this.init();
      }
    }

    getSlidesPerView() {
      if (window.innerWidth <= 767) return 1;
      if (window.innerWidth <= 1024) return 2;
      return 3;
    }

    init() {
      this.cloneSlides();
      this.setupEventListeners();
      this.goToSlide(this.slidesPerView, false);
      this.updateDots();

      if (this.autoplay) {
        this.startAutoplay();
      }
    }

    cloneSlides() {
      const clonesBefore = this.slides.slice(-this.slidesPerView).map(slide => {
        const clone = slide.cloneNode(true);
        clone.classList.add('clone');
        return clone;
      });

      const clonesAfter = this.slides.slice(0, this.slidesPerView).map(slide => {
        const clone = slide.cloneNode(true);
        clone.classList.add('clone');
        return clone;
      });

      clonesBefore.forEach(clone => this.track.insertBefore(clone, this.track.firstChild));
      clonesAfter.forEach(clone => this.track.appendChild(clone));

      this.allSlides = Array.from(this.track.children);
    }

    setupEventListeners() {
      if (this.prevBtn) {
        this.prevBtn.addEventListener('click', () => {
          this.prev();
          this.pauseAutoplayTemporarily();
        });
      }

      if (this.nextBtn) {
        this.nextBtn.addEventListener('click', () => {
          this.next();
          this.pauseAutoplayTemporarily();
        });
      }

      this.dots.forEach((dot, i) => {
        dot.addEventListener('click', () => {
          this.goToSlide(i + this.slidesPerView);
          this.updateDots();
          this.pauseAutoplayTemporarily();
        });
      });

      this.track.addEventListener('touchstart', (e) => {
        this.touchStartX = e.touches[0].clientX;
        this.pauseAutoplay();
      }, { passive: true });

      this.track.addEventListener('touchmove', (e) => {
        this.touchEndX = e.touches[0].clientX;
      }, { passive: true });

      this.track.addEventListener('touchend', () => {
        const diff = this.touchStartX - this.touchEndX;
        if (Math.abs(diff) > 50) {
          diff > 0 ? this.next() : this.prev();
          this.pauseAutoplayTemporarily();
        } else {
          this.resumeAutoplayDelayed();
        }
        this.touchStartX = 0;
        this.touchEndX = 0;
      });

      this.container.addEventListener('mouseenter', () => this.pauseAutoplay());
      this.container.addEventListener('mouseleave', () => this.resumeAutoplayDelayed());

      this.track.addEventListener('transitionend', () => this.handleTransitionEnd());

      window.addEventListener('resize', () => this.handleResize());
    }

    getRealIndex() {
      return ((this.currentIndex - this.slidesPerView) % this.slides.length + this.slides.length) % this.slides.length;
    }

    updateDots() {
      const realIndex = this.getRealIndex();
      this.dots.forEach((dot, i) => dot.classList.toggle('active', i === realIndex));
    }

    goToSlide(index, animate = true) {
      if (this.isTransitioning && animate) return;
      this.isTransitioning = true;
      this.currentIndex = index;

      if (!animate) {
        this.track.classList.add('no-transition');
      }

      this.updatePosition();

      if (!animate) {
        setTimeout(() => {
          this.track.classList.remove('no-transition');
          this.isTransitioning = false;
        }, 50);
      }
    }

    updatePosition() {
      const slideWidth = this.allSlides[0].offsetWidth;
      const gap = parseInt(window.getComputedStyle(this.track).gap) || 0;
      const offset = -(this.currentIndex * (slideWidth + gap));
      this.track.style.transform = `translateX(${offset}px)`;
    }

    handleTransitionEnd() {
      this.isTransitioning = false;

      if (this.currentIndex >= this.slides.length + this.slidesPerView) {
        this.track.classList.add('no-transition');
        this.currentIndex = this.slidesPerView;
        this.updatePosition();
        setTimeout(() => this.track.classList.remove('no-transition'), 50);
      } else if (this.currentIndex < this.slidesPerView) {
        this.track.classList.add('no-transition');
        this.currentIndex = this.slides.length + this.slidesPerView - 1;
        this.updatePosition();
        setTimeout(() => this.track.classList.remove('no-transition'), 50);
      }

      this.updateDots();
    }

    next() {
      if (this.isTransitioning) return;
      this.goToSlide(this.currentIndex + 1);
    }

    prev() {
      if (this.isTransitioning) return;
      this.goToSlide(this.currentIndex - 1);
    }

    startAutoplay() {
      if (!this.autoplay || this.autoplayInterval) return;
      this.autoplayInterval = setInterval(() => {
        if (!this.isPaused) this.next();
      }, this.autoplaySpeed);
    }

    pauseAutoplay() {
      this.isPaused = true;
      clearTimeout(this.resumeTimeout);
      this.resumeTimeout = null;
    }

    resumeAutoplayDelayed() {
      clearTimeout(this.resumeTimeout);
      if (this.autoplay) {
        this.resumeTimeout = setTimeout(() => {
          this.isPaused = false;
        }, 2000);
      }
    }

    pauseAutoplayTemporarily() {
      this.pauseAutoplay();
      this.resumeAutoplayDelayed();
    }

    handleResize() {
      const newSlidesPerView = this.getSlidesPerView();
      if (newSlidesPerView === this.slidesPerView) return;

      this.slidesPerView = newSlidesPerView;
      this.pauseAutoplay();
      clearInterval(this.autoplayInterval);
      this.autoplayInterval = null;

      this.track.innerHTML = '';
      this.slides.forEach(slide => {
        const original = slide.cloneNode(true);
        original.classList.remove('clone');
        this.track.appendChild(original);
      });
      this.slides = Array.from(this.track.querySelectorAll('[data-slide-index]'));
      this.currentIndex = 0;
      this.isTransitioning = false;

      if (this.slides.length > this.slidesPerView) {
        this.cloneSlides();
        this.goToSlide(this.slidesPerView, false);
        this.updateDots();
        if (this.autoplay) this.startAutoplay();
      }
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.product-hiw').forEach(el => new ProductHowItWorks(el));
    if (typeof lucide !== 'undefined') lucide.createIcons();
  });

  if (Shopify && Shopify.designMode) {
    document.addEventListener('shopify:section:load', (event) => {
      const el = event.target.querySelector('.product-hiw');
      if (el) {
        new ProductHowItWorks(el);
        if (typeof lucide !== 'undefined') lucide.createIcons();
      }
    });
  }
{% endjavascript %}

{% schema %}
{
  "name": "t:general.product_how_it_works",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "How it works"
    },
    {
      "type": "select",
      "id": "title_alignment",
      "label": "t:labels.title_alignment",
      "options": [
        { "value": "left", "label": "t:options.alignment.left" },
        { "value": "center", "label": "t:options.alignment.center" },
        { "value": "right", "label": "t:options.alignment.right" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "t:general.carousel_settings"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "t:labels.autoplay",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "t:labels.autoplay_speed",
      "info": "t:labels.autoplay_speed_info",
      "min": 1,
      "max": 8,
      "step": 1,
      "unit": "s",
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "t:labels.show_arrows",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "t:general.product_how_it_works",
      "category": "t:general.product"
    }
  ],
  "enabled_on": {
    "templates": ["product"]
  }
}
{% endschema %}
