{%- liquid
  assign empty_cart_text = section.settings.empty_cart_text | default: 'Your cart is empty'
  assign continue_shopping_text = section.settings.continue_shopping_text | default: 'Continue shopping'
  assign show_cart_note = section.settings.show_cart_note | default: false
-%}

<div class="cart-page">
  {%- if cart.item_count > 0 -%}
    <div class="cart-page__header">
      <h1 class="cart-page__title">{{ 'cart.title' | t }}</h1>
      <a href="{{ routes.all_products_collection_url }}" class="cart-page__continue-shopping">
        <i data-lucide="arrow-left" width="16" height="16"></i>
        <span>{{ continue_shopping_text }}</span>
      </a>
    </div>

    <form action="{{ routes.cart_url }}" method="post" class="cart-form" id="cart-form">
      <div class="cart-items">
        {%- for item in cart.items -%}
          <div class="cart-item" data-line-item="{{ forloop.index }}">
            <div class="cart-item__image">
              {%- if item.image -%}
                {{ item.image | image_url: width: 200 | image_tag: loading: 'lazy', alt: item.title }}
              {%- else -%}
                <div class="cart-item__no-image">
                  <i data-lucide="image-off" width="32" height="32"></i>
                </div>
              {%- endif -%}
            </div>

            <div class="cart-item__details">
              <div class="cart-item__info">
                <a href="{{ item.url }}" class="cart-item__title">{{ item.product.title }}</a>
                {%- unless item.product.has_only_default_variant -%}
                  <div class="cart-item__variant">{{ item.variant.title }}</div>
                {%- endunless -%}

                {%- if item.properties.size > 0 -%}
                  <div class="cart-item__properties">
                    {%- for property in item.properties -%}
                      {%- assign property_first_char = property.first | slice: 0 -%}
                      {%- if property.last != blank and property_first_char != '_' -%}
                        <div class="cart-item__property">
                          <span>{{ property.first }}:</span> {{ property.last }}
                        </div>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                {%- endif -%}

                {%- if item.selling_plan_allocation -%}
                  <div class="cart-item__subscription">
                    {{ item.selling_plan_allocation.selling_plan.name }}
                  </div>
                {%- endif -%}
              </div>

              <div class="cart-item__price">
                {%- if item.original_price != item.final_price -%}
                  <span class="cart-item__price--sale">{{ item.final_price | money }}</span>
                  <span class="cart-item__price--original">{{ item.original_price | money }}</span>
                {%- else -%}
                  <span>{{ item.final_price | money }}</span>
                {%- endif -%}
              </div>
            </div>

            <div class="cart-item__quantity">
              <div class="quantity-selector">
                <button type="button" class="quantity-selector__button" data-action="decrease" data-line="{{ forloop.index }}">
                  <i data-lucide="minus" width="16" height="16"></i>
                </button>
                <input
                  type="number"
                  name="updates[]"
                  id="updates_{{ item.key }}"
                  class="quantity-selector__input"
                  value="{{ item.quantity }}"
                  min="0"
                  data-line="{{ forloop.index }}"
                  aria-label="{{ 'products.quantity' | t }}"
                >
                <button type="button" class="quantity-selector__button" data-action="increase" data-line="{{ forloop.index }}">
                  <i data-lucide="plus" width="16" height="16"></i>
                </button>
              </div>
            </div>

            <div class="cart-item__total">
              {%- if item.original_line_price != item.final_line_price -%}
                <span class="cart-item__total--sale">{{ item.final_line_price | money }}</span>
                <span class="cart-item__total--original">{{ item.original_line_price | money }}</span>
              {%- else -%}
                <span>{{ item.final_line_price | money }}</span>
              {%- endif -%}
            </div>

            <button type="button" class="cart-item__remove" data-line="{{ forloop.index }}" aria-label="{{ 'cart.remove' | t }}">
              <i data-lucide="x" width="20" height="20"></i>
            </button>
          </div>
        {%- endfor -%}
      </div>

      <div class="cart-summary">
        {%- if show_cart_note -%}
          <div class="cart-note">
            <label for="cart-note" class="cart-note__label">{{ 'cart.note' | t }}</label>
            <textarea
              id="cart-note"
              name="note"
              class="cart-note__textarea"
              placeholder="{{ 'cart.note_placeholder' | t }}"
            >{{ cart.note }}</textarea>
          </div>
        {%- endif -%}

        <div class="cart-totals">
          <div class="cart-totals__line">
            <span>{{ 'cart.subtotal' | t }}</span>
            <span class="cart-totals__price">{{ cart.total_price | money }}</span>
          </div>

          {%- if cart.cart_level_discount_applications.size > 0 -%}
            {%- for discount in cart.cart_level_discount_applications -%}
              <div class="cart-totals__line cart-totals__discount">
                <span>{{ discount.title }}</span>
                <span class="cart-totals__price">-{{ discount.total_allocated_amount | money }}</span>
              </div>
            {%- endfor -%}
          {%- endif -%}

          <div class="cart-totals__note">
            {{ 'cart.taxes_and_shipping' | t }}
          </div>

          <button type="submit" name="checkout" class="cart-checkout-button">
            {{ 'cart.checkout' | t }}
          </button>
        </div>
      </div>
    </form>
  {%- else -%}
    <div class="cart-empty">
      <i data-lucide="shopping-cart" class="cart-empty__icon" width="64" height="64"></i>
      <h2 class="cart-empty__title">{{ empty_cart_text }}</h2>
      <a href="{{ routes.all_products_collection_url }}" class="cart-empty__button">
        {{ continue_shopping_text }}
      </a>
    </div>
  {%- endif -%}
</div>

{% javascript %}
  class CartManager {
    constructor() {
      this.form = document.getElementById('cart-form');
      if (!this.form) return;

      this.init();
    }

    init() {
      // Handle quantity buttons
      document.querySelectorAll('.quantity-selector__button').forEach(button => {
        button.addEventListener('click', this.handleQuantityChange.bind(this));
      });

      // Handle remove buttons
      document.querySelectorAll('.cart-item__remove').forEach(button => {
        button.addEventListener('click', this.handleRemove.bind(this));
      });

      // Handle direct input changes
      document.querySelectorAll('.quantity-selector__input').forEach(input => {
        input.addEventListener('change', this.handleInputChange.bind(this));
      });
    }

    handleQuantityChange(event) {
      const button = event.currentTarget;
      const action = button.dataset.action;
      const line = button.dataset.line;
      const input = this.form.querySelector(`input[data-line="${line}"]`);

      let newQuantity = parseInt(input.value);

      if (action === 'increase') {
        newQuantity += 1;
      } else if (action === 'decrease' && newQuantity > 0) {
        newQuantity -= 1;
      }

      input.value = newQuantity;
      this.updateCart(line, newQuantity);
    }

    handleRemove(event) {
      const button = event.currentTarget;
      const line = button.dataset.line;
      this.updateCart(line, 0);
    }

    handleInputChange(event) {
      const input = event.currentTarget;
      const line = input.dataset.line;
      const quantity = parseInt(input.value);

      if (quantity >= 0) {
        this.updateCart(line, quantity);
      }
    }

    updateCart(line, quantity) {
      const formData = new FormData();
      formData.append('updates[]', quantity);
      formData.append('line', line);

      fetch(window.Shopify.routes.root + 'cart/change.js', {
        method: 'POST',
        body: JSON.stringify({
          line: line,
          quantity: quantity
        }),
        headers: {
          'Content-Type': 'application/json'
        }
      })
      .then(response => response.json())
      .then(data => {
        window.location.reload();
      })
      .catch(error => {
        console.error('Error:', error);
      });
    }
  }

  // Initialize cart manager
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      new CartManager();
      if (typeof lucide !== 'undefined') {
        lucide.createIcons();
      }
    });
  } else {
    new CartManager();
    if (typeof lucide !== 'undefined') {
      lucide.createIcons();
    }
  }
{% endjavascript %}

{% stylesheet %}
  .cart-page {
    max-width: 1200px;
    margin: 0 auto;
    padding-bottom: 32px;
  }

  .cart-page__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 40px;
  }

  .cart-page__title {
    font-size: 2rem;
    font-weight: 600;
    margin: 0;
  }

  .cart-page__continue-shopping {
    color: var(--color-foreground);
    text-decoration: none;
    font-size: 14px;
    transition: opacity 0.2s ease;
    display: flex;
    align-items: center;
    gap: 6px;
    white-space: nowrap;
  }

  .cart-page__continue-shopping:hover {
    opacity: 0.7;
  }

  .cart-page__continue-shopping i {
    flex-shrink: 0;
  }

  .cart-form {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .cart-items {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .cart-item {
    display: grid;
    grid-template-columns: 100px 1fr auto auto;
    gap: 20px;
    align-items: center;
    padding: 20px;
    padding-right: 52px;
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 8px;
    background: var(--color-background);
    position: relative;
  }

  .cart-item__image {
    width: 100px;
    height: 100px;
    overflow: hidden;
    border-radius: 4px;
    background: #f5f5f5;
  }

  .cart-item__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cart-item__no-image {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ccc;
  }

  .cart-item__details {
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-width: 0;
  }

  .cart-item__title {
    font-size: 16px;
    font-weight: 500;
    color: var(--color-foreground);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .cart-item__title:hover {
    opacity: 0.7;
  }

  .cart-item__variant,
  .cart-item__property,
  .cart-item__subscription {
    font-size: 14px;
    color: #666;
  }

  .cart-item__properties {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .cart-item__property span {
    font-weight: 500;
  }

  .cart-item__price {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
    min-width: 100px;
  }

  .cart-item__price--sale {
    color: #e53e3e;
    font-weight: 500;
  }

  .cart-item__price--original {
    text-decoration: line-through;
    color: #999;
    font-size: 14px;
  }

  .quantity-selector {
    display: flex;
    align-items: center;
    gap: 4px;
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 4px;
    padding: 4px;
    background: var(--color-background);
    width: fit-content;
  }

  .cart-item__quantity {
    display: flex;
    align-items: center;
  }

  .quantity-selector__button {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    background: transparent;
    cursor: pointer;
    color: var(--color-foreground);
    transition: background 0.2s ease;
    border-radius: 2px;
  }

  .quantity-selector__button:hover {
    background: rgba(0, 0, 0, 0.05);
  }

  .quantity-selector__input {
    width: 50px;
    text-align: center;
    border: none;
    background: transparent;
    font-size: 14px;
    font-weight: 500;
    -moz-appearance: textfield;
  }

  .quantity-selector__input::-webkit-inner-spin-button,
  .quantity-selector__input::-webkit-outer-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .cart-item__total {
    min-width: 100px;
    text-align: right;
    font-weight: 600;
  }

  .cart-item__total--sale {
    color: #e53e3e;
  }

  .cart-item__total--original {
    display: block;
    text-decoration: line-through;
    color: #999;
    font-size: 14px;
    font-weight: 400;
  }

  .cart-item__remove {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    background: transparent;
    cursor: pointer;
    color: #999;
    transition: all 0.2s ease;
    border-radius: 4px;
  }

  .cart-item__remove:hover {
    color: #e53e3e;
    background: rgba(229, 62, 62, 0.05);
  }

  .cart-item__remove:active {
    transform: scale(0.95);
  }

  .cart-summary {
    display: flex;
    flex-direction: column;
    gap: 24px;
    width: 100%;
  }

  .cart-note {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .cart-note__label {
    font-size: 14px;
    font-weight: 500;
  }

  .cart-note__textarea {
    width: 100%;
    min-height: 80px;
    padding: 12px;
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 4px;
    font-family: inherit;
    font-size: 14px;
    resize: vertical;
  }

  .cart-totals {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 24px;
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 8px;
    background: var(--color-background);
  }

  .cart-totals__line {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 16px;
  }

  .cart-totals__discount {
    color: #38a169;
  }

  .cart-totals__price {
    font-weight: 600;
  }

  .cart-totals__note {
    font-size: 13px;
    color: #666;
    padding-top: 8px;
    border-top: 1px solid rgba(0, 0, 0, 0.1);
  }

  .cart-checkout-button {
    width: 100%;
    padding: 16px;
    background: var(--color-foreground);
    color: var(--color-background);
    border: none;
    border-radius: 4px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .cart-checkout-button::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
    transition: left 0.5s ease;
  }

  .cart-checkout-button::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.1) 0%, rgba(255, 255, 255, 0.05) 100%);
    opacity: 0;
    transition: opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    border-radius: 4px;
  }

  .cart-checkout-button:hover::before {
    left: 100%;
  }

  .cart-checkout-button:hover::after {
    opacity: 1;
  }

  .cart-checkout-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
  }

  .cart-checkout-button:active {
    transform: translateY(-1px);
    transition: all 0.1s ease;
  }

  .cart-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 24px;
    padding: 80px 20px;
    text-align: center;
  }

  .cart-empty__icon {
    color: #ccc;
  }

  .cart-empty__title {
    font-size: 1.5rem;
    font-weight: 500;
    color: #666;
    margin: 0;
  }

  .cart-empty__button {
    padding: 12px 32px;
    background: var(--color-foreground);
    color: var(--color-background);
    text-decoration: none;
    border-radius: 4px;
    font-weight: 500;
    position: relative;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    display: inline-block;
  }

  .cart-empty__button::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
    transition: left 0.5s ease;
  }

  .cart-empty__button::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.1) 0%, rgba(255, 255, 255, 0.05) 100%);
    opacity: 0;
    transition: opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    border-radius: 4px;
  }

  .cart-empty__button:hover::before {
    left: 100%;
  }

  .cart-empty__button:hover::after {
    opacity: 1;
  }

  .cart-empty__button:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
  }

  .cart-empty__button:active {
    transform: translateY(-1px);
    transition: all 0.1s ease;
  }

  @media (max-width: 768px) {
    .cart-page__header {
      gap: 12px;
      flex-wrap: wrap;
    }

    .cart-page__title {
      font-size: 1.5rem;
    }

    .cart-page__continue-shopping {
      font-size: 13px;
    }

    .cart-page__continue-shopping i {
      width: 14px;
      height: 14px;
    }

    .cart-item {
      grid-template-columns: 80px 1fr;
      grid-template-rows: auto auto auto auto;
      gap: 12px;
      padding: 16px;
      padding-right: 48px;
    }

    .cart-item__image {
      width: 80px;
      height: 80px;
      grid-row: 1 / 3;
      grid-column: 1;
    }

    .cart-item__details {
      grid-column: 2;
      grid-row: 1;
    }

    .cart-item__price {
      grid-column: 2;
      grid-row: 2;
      align-items: flex-start;
    }

    .cart-item__quantity {
      grid-column: 1 / -1;
      grid-row: 3;
    }

    .cart-item__total {
      grid-column: 1 / -1;
      grid-row: 4;
      text-align: left;
      padding-top: 4px;
      border-top: 1px solid rgba(0, 0, 0, 0.05);
    }

    .cart-item__remove {
      top: 8px;
      right: 8px;
      width: 28px;
      height: 28px;
    }

    .quantity-selector {
      gap: 4px;
      padding: 4px;
      width: 100%;
      max-width: none;
    }

    .quantity-selector__button {
      width: 32px;
      height: 32px;
      flex-shrink: 0;
    }

    .quantity-selector__button i {
      width: 16px;
      height: 16px;
    }

    .quantity-selector__input {
      flex: 1;
      font-size: 14px;
      padding: 0 8px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.cart",
  "settings": [
    {
      "type": "header",
      "content": "t:general.content"
    },
    {
      "type": "text",
      "id": "empty_cart_text",
      "label": "t:labels.empty_cart_text",
      "default": "Your cart is empty"
    },
    {
      "type": "text",
      "id": "continue_shopping_text",
      "label": "t:labels.continue_shopping_text",
      "default": "Continue shopping"
    },
    {
      "type": "checkbox",
      "id": "show_cart_note",
      "label": "t:labels.show_cart_note",
      "default": false
    }
  ]
}
{% endschema %}
